// ── INTERSECTION OBSERVER for cards ──
const cards = document.querySelectorAll('.chapter-card, .spirit-card, .element-card, .review-card, .occitanie-card');
const obs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = e.target.classList.contains('spirit-card') ? 'none' : 'translateY(0)';
    }
  });
}, {threshold:0.1});

cards.forEach((c,i) => {
  c.style.opacity = '0';
  if(!c.classList.contains('spirit-card')) c.style.transform = 'translateY(20px)';
  c.style.transition = `opacity 0.6s ${i*0.05}s, transform 0.6s ${i*0.05}s, border-color 0.3s, box-shadow 0.3s`;
  obs.observe(c);
});
